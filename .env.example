# DarkWiz Area Builder — optional configuration
# Rename to `.env` (next to docker-compose.yml) to apply.
# Anything not set falls back to the defaults baked into docker-compose.yml.

# Port the web UI is served on. Default 80.
# Set to e.g. 8080 if port 80 is already taken on your host.
FRONTEND_PORT=80

# Port the backend API listens on. Default 8000.
# Rarely needs changing — the frontend's nginx proxies /api/ to this
# port over the internal docker network.
BACKEND_PORT=8000

# Which image tag to pull. Default "latest".
# Pin to a specific release for reproducible installs:
#   IMAGE_TAG=v0.1.0
# Or stick with `latest` and run `docker compose pull` to update.
IMAGE_TAG=latest
